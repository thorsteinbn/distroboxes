{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "matchStringsStrategy": "any",
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\s*\\n\\s*[^\\s]*\\s*[^\\s]+=(?<currentValue>[^\\s\\\\]+)"
      ],
      "managerFilePatterns": [
        "**/Containerfile"
      ],
      "datasourceTemplate": "{{datasource}}",
      "depNameTemplate": "{{depName}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "tofuutils/tenv",
        "gitlab-org/cli"
      ],
      "automerge": true
    }
  ]
}
